# アプリケーション設定
APP_NAME=Smart-EMAP
SERVER_NAME=生産管理システム
APP_ENV=development
DEBUG=True
SECRET_KEY=

# データベース設定
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=eams_db
# DATABASE_URLは自動生成されます（DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAMEから）

# ---------- MySQL 全庫バックアップ（mysqldump）----------
# UI 未設定時の既定保存先（UNC 可）。システム設定の storage_path が有効ならそちらを優先。
# BACKUP_DEFAULT_STORAGE_PATH=\\\\192.168.1.200\\社内共有\\02_生産管理部\\バックアップ\\Mysql-backup
# mysqldump が PATH に無い場合
# MYSQLDUMP_BIN=C:\\Program Files\\MySQL\\MySQL Server 8.0\\bin\\mysqldump.exe

# FastAPI プロセス内の日次自動バックアップ（TIMEZONE で HH:MM を解釈。複数 worker では重複し得る）
# DB_AUTO_BACKUP_ENABLED=false
# DB_AUTO_BACKUP_TIME=02:00
# 当日の正点を逃したあとにサーバを起動したとき、起動直後に 1 回だけ補完する（同日に正点でもう 1 回走ることがある）
# DB_AUTO_BACKUP_CATCHUP_ON_START=true
# BackupSetting 行が無いときの既定（行があれば DB の retention / 圧縮を優先）
# DB_AUTO_BACKUP_RETENTION=7
# DB_AUTO_BACKUP_COMPRESS=true

# 一键建库脚本 scripts/bootstrap_full_database.py 用：mysql 客户端不在 PATH 时指定全路径（可选）
# MYSQL_BIN=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysql.exe

# JWT設定
JWT_SECRET=smart_secret
JWT_SECRET_KEY=smart_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600

# 開発 LAN IP（省略時 start.py が本机 IP を自動検出 → http://<自動IP>:5001/）
# DEV_LAN_IP=

# HTTPS（start.py: 未設定時は true。証明書未指定なら backend/certs/dev-lan.* を自動生成し
#   開発: https://<LAN-IP>:5000/ + http://<LAN-IP>:5001/
#   本番: https://<LAN-IP>:5005/ ・http://<LAN-IP>:3005/ ・API :8005/
#   無効化: START_DISABLE_AUTO_HTTPS=1）
HTTPS_ENABLED=true
# 相対パスは backend/ またはリポジトリルートからのパス可（空なら dev-lan を自動生成）
SSL_CERTFILE=
SSL_KEYFILE=
# start.py のみ: 自動 HTTPS を完全オフ（.env の HTTPS_ENABLED=false を尊重）
# START_DISABLE_AUTO_HTTPS=1

# CORS設定
# CORS設定（開発環境でネットワークアクセスを許可する場合）
# 複数のオリジンを指定する場合は、カンマ区切りで指定
# HTTPS でフロントを開く場合は https://... も追加するか、開発で CORS_ALLOW_ALL=true
CORS_ORIGINS=["http://localhost:5001", "http://127.0.0.1:5001", "https://localhost:5000", "https://127.0.0.1:5000", "http://localhost:3000"]

# 開発環境ですべてのオリジンを許可する場合（ネットワークアクセス対応）
# CORS_ALLOW_ALL=true に設定すると、すべてのIPアドレスからのアクセスを許可
CORS_ALLOW_ALL=false

# ---------- AI 助手（Ollama 本地开源模型）----------
# 服务器安装 Ollama 后执行: ollama pull qwen2.5:7b
# AI_ENABLED=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_TIMEOUT_SECONDS=120
# AI_MAX_TOOL_ROUNDS=8
# AI_QUERY_MAX_LIMIT=100

# タイムゾーン
TIMEZONE=Asia/Tokyo

# ログ設定
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 文件监视：两个目录，.env 请保存为 UTF-8
# CSV 受信（库存/材料 CSV）
FILE_WATCH_BASE_PATH=\\\\192.168.1.200\\社内共有\\02_生産管理部\\Data\\BT-data\\受信
# Excel 計画（加工・溶接 24 个 .xlsm）
FILE_WATCH_EXCEL_BASE_PATH=\\\\192.168.1.200\\社内共有\\02_生産管理部\\生産計画
FILE_WATCH_POLL_INTERVAL=1.0
FILE_WATCH_DEBOUNCE_SEC=2
FILE_WATCH_CSV_WORKERS=2
FILE_WATCH_EXCEL_WORKERS=3
# 在庫 CSV（MoldingRecord 等）: 直近 N 日だけ DELETE→INSERT（0=全件置換）。本日含む 7 日が既定
FILE_WATCH_STOCK_REPLACE_DAYS=7
FILE_WATCH_STOCK_SKIP_UNCHANGED=true
FILE_WATCH_STOCK_INSERT_BATCH=2000

# 検査管理指標 Excel → inspection_management（入力相当シート）
# FILE_WATCH_INSPECTION_EXCEL_PATH=\\\\192.168.1.200\\製造部\\11各工程生産管理指標\\4.検査工程\\2026年度\\生産管理指標(2026年度-検査).xlsx
# FILE_WATCH_INSPECTION_MGMT_SYNC_ENABLED=true

# 溶接管理指標 Excel → welding_management（入力シート）
FILE_WATCH_WELDING_EXCEL_PATH=\\\\192.168.1.200\\製造部\\11各工程生産管理指標\\5.溶接工程\\2026年度\\生産管理指標(2026年度-溶接).xlsx
FILE_WATCH_WELDING_MGMT_SYNC_ENABLED=true

# 切断管理指標 Excel → cutting_production_indicator
FILE_WATCH_CUTTING_EXCEL_PATH=\\\\192.168.1.200\\製造部\\11各工程生産管理指標\\1.切断工程\\2026年度\\生産管理指標(2026年度-切断).xlsx
FILE_WATCH_CUTTING_INDICATOR_SYNC_ENABLED=true

# 成形管理指標 Excel → forming_production_indicator
FILE_WATCH_FORMING_EXCEL_PATH=\\\\192.168.1.200\\製造部\\11各工程生産管理指標\\3.成形工程\\2026年度\\生産管理指標(2026年度-成形).xlsx
FILE_WATCH_FORMING_INDICATOR_SYNC_ENABLED=true

# LINE（Channel Token / Secret）は .env ではなく
# システム設定 → 通知センター → 外部連携 → LINE で保存（DB: integration_configs）
#
# LINE Webhook（User ID 収集）URL 例:
#   https://<你的域名>/api/line/webhook
# 本地调试可用 ngrok: ngrok http 8000 → 将 https://xxx.ngrok-free.app/api/line/webhook 填到 LINE Developers
# 前提: 通知センター已保存 Channel Secret（用于签名校验）