# Smart-EMAP Backend 環境変数サンプル（機密値は含めない）
# コピー: cp .env.example .env

# --- 自動車ニュースティッカー（MainLayout 上部 RSS スクロール）---
AUTO_NEWS_ENABLED=false
AUTO_NEWS_CACHE_TTL_SECONDS=1800
AUTO_NEWS_MAX_ITEMS=20
# カンマ区切り。各要素: RSS_URL または RSS_URL|表示名
# AUTO_NEWS_RSS_URLS=https://news.yahoo.co.jp/rss/media/norimono/all.xml|乗りものニュース,https://response.jp/rss/index.rdf|レスポンス
# トヨタ・ホンダ・日産関連のみ（タイトル/概要のキーワード一致）
# AUTO_NEWS_BRAND_KEYWORDS=トヨタ,豊田,Toyota,ホンダ,本田,Honda,日産,Nissan
