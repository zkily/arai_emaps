flowchart LR
  START(["担当者"]):::start
  OPEN["次製品指定<br/>を開く"]:::step
  CHOICE{稼働中?}
  NEXT["次製品"]:::active
  FIRST["初回製品"]:::idle
  SAVE["保存"]:::save
  STRIP["参考バー表示"]:::result
  PICK["生産開始"]:::action

  START --> OPEN --> CHOICE
  CHOICE -->|Yes| NEXT --> SAVE
  CHOICE -->|No| FIRST --> SAVE
  SAVE --> STRIP --> PICK

  classDef start fill:#0f172a,stroke:#0f172a,color:#fff,stroke-width:2px
  classDef step fill:#f8fafc,stroke:#64748b,color:#334155,stroke-width:1.5px
  classDef active fill:#eff6ff,stroke:#3b82f6,color:#1e40af,stroke-width:1.5px
  classDef idle fill:#f0fdfa,stroke:#14b8a6,color:#0f766e,stroke-width:1.5px
  classDef save fill:#6366f1,stroke:#4f46e5,color:#fff,stroke-width:1.5px
  classDef result fill:#eef2ff,stroke:#6366f1,color:#4338ca,stroke-width:1.5px
  classDef action fill:#f5f3ff,stroke:#8b5cf6,color:#5b21b6,stroke-width:1.5px
