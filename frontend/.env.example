# Vite 開発サーバー（npm run dev）
# backend/.env で HTTPS_ENABLED=true のとき、start.py が VITE_* を自動注入することもあります。

# true: https://localhost:5000 で起動（ブラウザは証明書警告を確認）
VITE_DEV_HTTPS=false
# バックエンド API プロキシ先（未設定時は VITE_API_HTTPS で http/https を切替）
# VITE_API_PROXY_TARGET=https://localhost:8005
VITE_API_HTTPS=false
# 開発用証明書（start.py と同じ PEM を指定すると警告を減らせます）
# VITE_SSL_CERTFILE=../backend/certs/dev.crt
# VITE_SSL_KEYFILE=../backend/certs/dev.key
# WebSocket プロキシ（通常は自動。独自ポート時のみ）
# VITE_WS_PROXY_TARGET=wss://localhost:8005

# --- 本番ビルド（npm run build / dist）---
# .env.production に以下を置くか、ビルド前に環境変数を設定してください。
# VITE_API_HTTPS=true のとき、VITE_API_BASE_URL が未設定なら dist 内に
# https://localhost:8005（または VITE_API_PROXY_TARGET）が埋め込まれます。
# VITE_API_BASE_URL=https://192.168.1.59:8005
