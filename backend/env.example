# アプリケーション設定
APP_NAME=Smart-EMAP
SERVER_NAME=生産管理システム
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# データベース設定
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=136228508
DB_NAME=eams_db
# DATABASE_URLは自動生成されます（DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAMEから）

# ---------- MySQL 全庫バックアップ（mysqldump）----------
# UI 未設定時の既定保存先（UNC 可）。システム設定の storage_path が有効ならそちらを優先。
# BACKUP_DEFAULT_STORAGE_PATH=\\\\192.168.1.200\\社内共有\\02_生産管理部\\バックアップ\\Mysql-backup
# mysqldump が PATH に無い場合
# MYSQLDUMP_BIN=C:\\Program Files\\MySQL\\MySQL Server 8.0\\bin\\mysqldump.exe

# FastAPI プロセス内の日次自動バックアップ（TIMEZONE で HH:MM を解釈。複数 worker では重複し得る）
# DB_AUTO_BACKUP_ENABLED=false
# DB_AUTO_BACKUP_TIME=02:00
# 当日の正点を逃したあとにサーバを起動したとき、起動直後に 1 回だけ補完する（同日に正点でもう 1 回走ることがある）
# DB_AUTO_BACKUP_CATCHUP_ON_START=true
# BackupSetting 行が無いときの既定（行があれば DB の retention / 圧縮を優先）
# DB_AUTO_BACKUP_RETENTION=7
# DB_AUTO_BACKUP_COMPRESS=true

# 一键建库脚本 scripts/bootstrap_full_database.py 用：mysql 客户端不在 PATH 时指定全路径（可选）
# MYSQL_BIN=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysql.exe

# JWT設定
JWT_SECRET=smart_secret
JWT_SECRET_KEY=smart_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600

# HTTPS（start.py 時: API(8005) と dist 本番(3005) の両方が同一証明書で TLS 終端。自己署名可）
HTTPS_ENABLED=false
# 相対パスは backend/ またはリポジトリルートからのパス可
SSL_CERTFILE=
SSL_KEYFILE=

# CORS設定
# CORS設定（開発環境でネットワークアクセスを許可する場合）
# 複数のオリジンを指定する場合は、カンマ区切りで指定
# HTTPS でフロントを開く場合は https://... も追加するか、開発で CORS_ALLOW_ALL=true
CORS_ORIGINS=["http://localhost:5000", "http://localhost:3000", "http://127.0.0.1:5000"]

# 開発環境ですべてのオリジンを許可する場合（ネットワークアクセス対応）
# CORS_ALLOW_ALL=true に設定すると、すべてのIPアドレスからのアクセスを許可
CORS_ALLOW_ALL=false

# タイムゾーン
TIMEZONE=Asia/Tokyo

# ログ設定
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 文件监视：两个目录，.env 请保存为 UTF-8
# CSV 受信（库存/材料 CSV）
FILE_WATCH_BASE_PATH=\\\\192.168.1.200\\社内共有\\02_生産管理部\\Data\\BT-data\\受信
# Excel 計画（加工・溶接 24 个 .xlsm）
FILE_WATCH_EXCEL_BASE_PATH=\\\\192.168.1.200\\社内共有\\02_生産管理部\\生産計画
FILE_WATCH_POLL_INTERVAL=1.0
FILE_WATCH_DEBOUNCE_SEC=2

